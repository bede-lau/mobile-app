{
  "expo": {
    "name": "Olvon",
    "slug": "olvon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "olvon",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FAFAF7",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.olvon.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Olvon needs camera access to create your 3D body avatar for virtual fitting.",
        "NSPhotoLibraryUsageDescription": "Olvon needs photo access to save your avatar images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF7"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.olvon.app",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Olvon needs camera access to create your 3D body avatar."
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      "expo-web-browser",
      "expo-video",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "da8d5369-4e91-484d-b3f1-3e59397ed103"
      }
    },
    "owner": "bedes-organization"
  }
}
